generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Category {
  KAMBING
  SAPI
  KERBAU
  AQIQAH
}

model Product {
  id          String   @id @default(cuid())
  name        String
  category    Category
  price       Int?
  label       String?
  image       String?
  externalUrl String?
  isActive    Boolean  @default(true)
  description String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Banner {
  id          String    @id @default(cuid())
  name        String
  category    Category?
  price       Int?
  label       String?
  image       String?
  externalUrl String?
  isActive    Boolean   @default(true)
  headline    String?
  subheadline String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Section {
  id          String    @id @default(cuid())
  name        String
  category    Category?
  price       Int?
  label       String?
  image       String?
  externalUrl String?
  isActive    Boolean   @default(true)
  title       String?
  content     String?
  kind        String    @default("feature")
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
